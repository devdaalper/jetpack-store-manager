# ─── Backblaze B2 Credentials ────────────────────────────────────────
# Required for catalog sync and audio file access.
B2_KEY_ID=your-key-id-here
B2_APP_KEY=your-application-key-here
B2_BUCKET=your-bucket-name
B2_PREFIX=optional/path/prefix/

# ─── WordPress REST API ─────────────────────────────────────────────
# Base URL of the WordPress site (no trailing slash).
WP_BASE_URL=https://your-site.com
# Desktop API token generated in MediaVault Manager settings.
WP_DESKTOP_TOKEN=your-desktop-api-token-here

# ─── Notes ───────────────────────────────────────────────────────────
# The desktop app stores credentials in the macOS Keychain via the GUI.
# This file is a reference for the required values — you do NOT need to
# source it. Copy to .env and fill in your values for documentation only.
