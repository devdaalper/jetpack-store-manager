{
  "name": "daalper/jetpack-store-manager",
  "description": "JetPack Store Manager (tests + release discipline)",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0",
    "szepeviktor/phpstan-wordpress": "^2.0"
  },
  "autoload": {
    "classmap": [
      "includes/"
    ]
  },
  "scripts": {
    "test": "vendor/bin/phpunit -c ../../03-PROYECTO-TRABAJO/phpunit.xml",
    "integration": "php ../../03-PROYECTO-TRABAJO/scripts/integration/wpnow_endpoints_test.php",
    "security:gate": "bash ../../03-PROYECTO-TRABAJO/SKILLS/mediavault-manager-security-gate/scripts/security_gate.sh --build",
    "release:verify": [
      "@test",
      "@integration",
      "@security:gate"
    ]
  }
}
