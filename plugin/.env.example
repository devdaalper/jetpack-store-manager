# ─── Backblaze B2 Credentials (wp-config.php) ───────────────────────
# RECOMMENDED: Define these as constants in wp-config.php for security.
# The plugin falls back to wp_options if not defined in wp-config.php.
#
#   define('JPSM_B2_KEY_ID',          'your-key-id');
#   define('JPSM_B2_APP_KEY',         'your-app-key');
#   define('JPSM_B2_BUCKET',          'your-bucket');
#   define('JPSM_B2_REGION',          'us-west-004');
#   define('JPSM_CLOUDFLARE_DOMAIN',  'cdn.example.com');

JPSM_B2_KEY_ID=your-key-id
JPSM_B2_APP_KEY=your-application-key
JPSM_B2_BUCKET=your-bucket-name
JPSM_B2_REGION=us-west-004
JPSM_CLOUDFLARE_DOMAIN=cdn.example.com

# ─── Development ─────────────────────────────────────────────────────
# Set SCRIPT_DEBUG to true in wp-config.php to load unminified JS/CSS:
#   define('SCRIPT_DEBUG', true);
